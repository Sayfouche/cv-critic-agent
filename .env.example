CV_CRITIC_PROVIDER=mistral
CV_CRITIC_MODEL=mistral-medium-latest
MISTRAL_API_KEY=your_mistral_api_key_here

# FastAPI server / real-run protection
CV_CRITIC_API_TOKEN=change-me-for-real-runs
CV_CRITIC_ALLOWED_ORIGINS=http://localhost:3000

# Optional Anthropic fallback:
# CV_CRITIC_PROVIDER=anthropic
# CV_CRITIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Phase 5 — Access gate ────────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
HMAC_KEY=change-me-to-a-random-hex-string

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=change-me-to-a-fernet-key

# Cloudflare Turnstile server-side secret (free tier)
TURNSTILE_SECRET=your_turnstile_secret_here

# Telegram bot (create via BotFather → /newbot)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_OWNER_CHAT_ID=your_telegram_chat_id_here

# Resend transactional email (resend.com)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM_ADDRESS=agent@cv-critic.saifallah.dev

# Admin magic-link login
OWNER_EMAIL=mansour.saifallah@gmail.com

# URLs (used to build decision links + session links)
CV_CRITIC_BASE_URL=https://cv-critic-agent-api.onrender.com
CV_CRITIC_UI_URL=https://agentic-ai.saifallah.dev

# Local path for access-request JSON files
ACCESS_REQUESTS_DIR=data/access_requests

# ── Phase 5 Sprint 5 — Daily budget cap ──────────────────────────────────────
# Maximum LLM output tokens consumed per UTC day before real runs degrade
# silently to mock. Defaults to 200000 (~$5/day on Mistral medium).
MAX_TOKENS_PER_DAY=200000

# Local path for per-day budget JSON files
BUDGET_DIR=data/budget
